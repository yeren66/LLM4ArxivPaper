# Copy to .env.local for local development; in production set these in the
# Vercel project's Environment Variables.

# ─── Upstash Redis (auto-injected by Vercel when the Upstash integration ───
# is installed; only fill these locally if you want to test against a real
# Redis. Without them, lib/kv.ts uses an in-memory Map for dev. )
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Single-user write token ──────────────────────────────────────────────
# Anyone with this token (presented as the `llm4arxiv_admin` cookie) can
# submit URLs / star / chat. Public read access does not require it.
ADMIN_TOKEN=replace-me-with-a-long-random-string

# ─── GitHub workflow_dispatch token (fine-grained PAT) ────────────────────
# Used by /api/papers/ingest to trigger analyse-one.yml, by /api/cron/keepalive
# to keep the weekly cron alive, and by /api/cron/archive-to-git to snapshot
# KV state back into the repo.
# Required PAT scopes:
#   Repository: LLM4ArxivPaper
#   Permissions: Contents (Read and write) + Actions (Read and write) + Metadata (Read)
GH_DISPATCH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional — Vercel auto-injects VERCEL_GIT_REPO_OWNER / VERCEL_GIT_REPO_SLUG
# when the project is linked to a repo, so these are usually unnecessary in
# production. Set them only if you're running outside of a Vercel deployment.
GH_REPO_OWNER=
GH_REPO_NAME=

# ─── LLM for the chat endpoint ────────────────────────────────────────────
# Same key/url you use in GitHub Secrets for the Python pipeline. The model
# name is read from config/pipeline.yaml (openai.summarization_model); set
# LLM_MODEL here only if you want the chat endpoint to use a different model
# from the analysis pipeline.
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=

# ─── Archive policy ────────────────────────────────────────────────────────
# Defaults live in config/pipeline.yaml under `archive:` — set these env vars
# only to override per deployment. The daily /api/cron/archive-to-git job
# snapshots live KV state into the git repo as a backup + audit log.
#
#   ARCHIVE_STARS  default true   — "papers I starred" is low-sensitivity;
#                                   the git backup is worth having.
#   ARCHIVE_CHATS  default false  — your LLM conversations can reveal what
#                                   you're researching. OFF by default so a
#                                   misconfigured PUBLIC repo never leaks them.
#                                   If your instance repo is PRIVATE (the
#                                   recommended setup) set this to `true`.
# ARCHIVE_STARS=
# ARCHIVE_CHATS=

# ─── Optional ──────────────────────────────────────────────────────────────
# Shared secret for curl-testing the cron routes. When set, you must pass
# `Authorization: Bearer $CRON_SECRET`. Vercel cron itself carries an
# `x-vercel-cron` header that bypasses this check.
CRON_SECRET=
